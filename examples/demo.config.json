{
  "servers": {
    "echo1": {
      "transport": "stdio",
      "command": ["node", "node_modules/tsx/dist/cli.mjs", "tests/fixtures/echo-mcp-server/stdio.ts"],
      "env": { "ECHO_SERVER_NAME": "echo1" }
    },
    "echo2": {
      "transport": "stdio",
      "command": ["node", "node_modules/tsx/dist/cli.mjs", "tests/fixtures/echo-mcp-server/stdio.ts"],
      "env": { "ECHO_SERVER_NAME": "echo2" }
    }
  },
  "shrink": {
    "mode": "rules",
    "maxDescriptionChars": 60,
    "cachePath": ".mcp-diet/shrink-cache.json"
  },
  "observability": {
    "trace": { "sink": "off" }
  },
  "inbound": {
    "stdio": false,
    "http": { "enabled": false }
  },
  "logLevel": "silent"
}
