  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Upstream up",
      "type": "stat",
      "targets": [
        {
          "expr": "lean_mcp_upstream_up",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "title": "Tool calls / second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (upstream) (rate(lean_mcp_calls_total[1m]))",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Tool call latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, upstream) (rate(lean_mcp_call_duration_ms_bucket[5m])))",
          "legendFormat": "{{upstream}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Tokens saved per upstream",
      "type": "timeseries",
      "targets": [
        {
          "expr": "lean_mcp_tokens_saved",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "title": "Tool call errors / second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (upstream, tool) (rate(lean_mcp_calls_total{ok=\"false\"}[1m]))",
          "legendFormat": "{{upstream}}.{{tool}}",
          "refId": "A"
        }
      ]
    }
  ],
